# Environment variables for Temporiq AI
# Copy this file to .env and fill in your values

# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key

# Google Cloud (Vertex AI) Configuration
# Get these from your Google Cloud project
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=your-gcp-location

# Application Configuration
ADMIN_EMAIL=your_admin_email@example.com # Email for the user who sees the detailed System Status page

# Optional: Specify a different Gemini model. Defaults to gemini-2.5-pro if not set.
# GCP_MODEL_NAME=gemini-2.5-pro
